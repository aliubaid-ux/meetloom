# Application
PORT=3000
NODE_ENV=development
SESSION_SECRET=your_session_secret_here

# Google OAuth Credentials
# You can get these by creating an OAuth 2.0 Client ID in the Google Cloud Console
# Ensure you add https://www.googleapis.com/auth/youtube.upload to your requested scopes
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Note: In production, the REDIRECT_URI must match your deployed HTTPS domain.
